type MockFileInfo struct {
	name    string
	size    int64
	mode    os.FileMode
	modTime time.Time
	isDir   bool
	sys     interface{}
}

func (m *MockFileInfo) Name() string       { return m.name }
func (m *MockFileInfo) Size() int64        { return m.size }
func (m *MockFileInfo) Mode() os.FileMode  { return m.mode }
func (m *MockFileInfo) ModTime() time.Time { return m.modTime }
func (m *MockFileInfo) IsDir() bool        { return m.isDir }
func (m *MockFileInfo) Sys() interface{}   { return m.sys }

type SecretFS struct {
	content secrets.RestructuredSecrets
}

type secretFile struct {
	content secrets.RestructuredSecrets
	cursor  int64
}

func (sfs SecretFS) Open(name string) (fs.File, error) {
	if len(sfs.content) == 0 {
		return nil, fs.ErrNotExist
	}
	return &secretFile{
		content: sfs.content,
		cursor:  0,
	}, nil
}

func (sf *secretFile) Stat() (fs.FileInfo, error) {
	return &MockFileInfo{}, nil

}
func (sf *secretFile) Read(out []byte) (int, error) {
	if sf.cursor >= int64(len(sf.content)) {
		return 0, io.EOF
	}
	n := copy(out, sf.content[sf.cursor:])
	sf.cursor += int64(n)
	return n, nil
}
func (sf *secretFile) Close() error {
	return nil
}
