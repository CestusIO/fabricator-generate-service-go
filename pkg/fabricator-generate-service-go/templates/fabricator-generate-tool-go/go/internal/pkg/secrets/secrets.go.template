//ProvideSecretFlagSet provides a flag set
func ProvideSecretFlagSet() *secrets.SecretFlagSet {
	return &secrets.SecretFlagSet{FlagSet: *flags.NewFlagSet("{{.PluginComponent.Spec.ToolName}}")}
}

// ProvideSecrets provides a secrets
func ProvideSecrets(secretSet *secrets.SecretFlagSet, secretConfig *secrets.Config, restructuredSecrets secrets.RestructuredSecrets) (Secrets, error) {
	secrets := Secrets{
		App: app.RegisterSecrets(secretSet),
		S2SAuth: s2sauth.RegisterSecrets(secretSet),
{{ if .PluginComponent.Spec.HasRelationalDatabase -}}
		Data: data.RegisterSecrets(secretSet),
{{ end -}}
// endregion

	}

secretFS := SecretFS{content: restructuredSecrets}

// region CODE_REGION(COMMON_FLAGSET)
	_ = secretSet.String(0, "config", "", "config file (optional)")
	options := []ff.Option{
		ff.WithConfigFileFlag("config"),
		ff.WithFilesystem(secretFS),
		ff.WithConfigFileParser(ffjson.Parse),
		ff.WithConfigIgnoreUndefinedFlags(),
		ff.WithEnvVarPrefix("{{.PluginComponent.Spec.ToolName | ToEnvVarName}}"),
		secretSet.WithArgsIgnoreUndefinedFlags(),

	}
	if !secretConfig.Enabled {
		options = append(options, ff.WithConfigAllowMissingFile())
	}
	// skip until the first flag
	args := os.Args
	for len(args) > 0 {
		arg := args[0]
		if strings.HasPrefix(arg, "-") {
			break
		}
		args = args[1:]
	}
	err := ff.Parse(&secretSet.FlagSet, args, options...)
	if errors.Is(err, flags.ErrHelp) {
		err = nil
	}
// endregion
	return secrets, err
}
